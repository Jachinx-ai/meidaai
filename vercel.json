{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/", "destination": "/login.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}
